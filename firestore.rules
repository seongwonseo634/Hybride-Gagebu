rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if the user is a member of the group
    function isMember(groupId) {
      return request.auth.uid in get(/databases/$(database)/documents/groups/$(groupId)).data.memberIds;
    }
    
    // Check if the user is an admin of the group
    function isAdmin(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data.ownerId == request.auth.uid;
    }

    // User profile
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      
      // User budgets, assets, recurring
      match /budgets/{budgetId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /assets/{assetId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /recurring/{recurringId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
      match /challenges/{challengeId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // User goals
    match /users/{userId}/goals/{goalId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Personal transactions
    match /users/{userId}/transactions/{transactionId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // User notifications
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // User preferences
    match /users/{userId}/preferences/{prefId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Legacy/Root transactions (for recovery/diagnosis)
    match /transactions/{id} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if isSignedIn() && request.auth.uid == resource.data.userId;
    }

    // Groups
    match /groups/{groupId} {
      allow list: if isSignedIn();
      allow get: if true; // Allow anyone to see group info if they have the ID for join/invite screen
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.ownerId || 
        (
          request.resource.data.memberIds.hasAll(resource.data.memberIds) && 
          request.resource.data.memberIds.hasAny([request.auth.uid]) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberProfiles'])
        )
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.ownerId;
    }

    // Group members
    match /groups/{groupId}/members/{memberId} {
      allow read: if isSignedIn() && (request.auth.uid == memberId || isMember(groupId));
      allow create, update: if isSignedIn() && request.auth.uid == memberId && request.resource.data.role == 'member';
      allow delete, update: if isSignedIn() && isAdmin(groupId);
    }
    
    // Group transactions
    match /groups/{groupId}/transactions/{transactionId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isMember(groupId);
      allow create, update, delete: if isSignedIn() && isMember(groupId);
    }
    
    // Group dues
    match /groups/{groupId}/dues/{dueId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && isMember(groupId);
      allow create, update, delete: if isSignedIn() && isAdmin(groupId);
    }
    
    // Group due payments
    match /groups/{groupId}/dues/{dueId}/payments/{paymentId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn() && (request.auth.uid == paymentId || isAdmin(groupId));
      allow write: if isSignedIn() && request.auth.uid == paymentId;
    }
  }
}
